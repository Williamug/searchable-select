{
  "name": "williamug/searchable-select",
  "description": "A beautiful, searchable dropdown component for Laravel Livewire 3 & 4 applications. Built with Alpine.js and Tailwind CSS - no external dependencies required!",
  "keywords": [
    "Williamug",
    "laravel",
    "searchable-select",
    "livewire",
    "select",
    "dropdown",
    "searchable-dropdown",
    "select2"
  ],
  "homepage": "https://github.com/williamug/searchable-select",
  "license": "MIT",
  "authors": [
    {
      "name": "William Asaba",
      "email": "asabawilliamdk@yahoo.com",
      "role": "Developer"
    }
  ],
  "require": {
    "php": "^8.2",
    "illuminate/contracts": "^11.0||^12.0||^13.0",
    "livewire/livewire": "^3.0||^4.0"
  },
  "require-dev": {
    "laravel/pint": "^1.14",
    "nunomaduro/collision": "^8.8",
    "orchestra/testbench": "^10.0.0||^9.0.0",
    "pestphp/pest": "^4.0",
    "pestphp/pest-plugin-arch": "^4.0",
    "pestphp/pest-plugin-laravel": "^4.0"
  },
  "autoload": {
    "psr-4": {
      "Williamug\\SearchableSelect\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Williamug\\SearchableSelect\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "post-autoload-dump": "@composer run prepare",
    "prepare": "@php vendor/bin/testbench package:discover --ansi",
    "analyse": "vendor/bin/phpstan analyse",
    "test": "vendor/bin/pest",
    "test-coverage": "vendor/bin/pest --coverage",
    "format": "vendor/bin/pint"
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true,
      "phpstan/extension-installer": true
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Williamug\\SearchableSelect\\SearchableSelectServiceProvider"
      ]
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
